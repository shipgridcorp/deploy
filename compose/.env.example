# ShipGrid single-VM (Docker Compose) — environment.
# Copy to .env in this directory (install.sh does it for you) and edit.
# Every value has a working PoC default in docker-compose.yml; this file is the
# single place where an install differs from the defaults.

# ── Image source ──────────────────────────────────────────────────────────────
# Where the ShipGrid service images come from. Pull credentials are issued with
# your delivery:  docker login registry.shipgrid.app
# Air-gap: images are loaded from the bundle (install.sh --bundle) under this
# same namespace, or point REGISTRY at your internal mirror.
REGISTRY=registry.shipgrid.app/shipgrid
# Per-service tags default inside docker-compose.yml (the tested release set).
# Override individual tags here only when instructed with a release:
# GATE_TAG=v1.28.0
# BILLING_TAG=v1.43.0

# ── On-prem license ───────────────────────────────────────────────────────────
# The signed license.signed.json arrives with your delivery; the public key that
# verifies it is embedded in the images. EVERY backend service verifies the
# license at startup. A valid-but-expired license degrades to restricted (read-
# only) mode after its grace period — it does not stop the platform; only a
# missing/invalid license fails closed.
LICENSE_ENABLED=true
# Host path to the signed license file (mounted read-only into every service).
LICENSE_FILE_HOST=./license.json
# Advanced: override the embedded trust-root public key (unsigned/dev builds
# only — ignored when the image already has a key baked in). Leave empty.
# LICENSE_PUBLIC_KEY=

# ── LLM ───────────────────────────────────────────────────────────────────────
# Block foreign LLM providers (152-ФЗ). Keep true for any RF deployment.
BLOCK_FOREIGN_LLM=true
# Built-in mock provider: true lets the stack run with NO real LLM (demo / no
# GPU). Set false once a real provider below is configured.
MOCK_PROVIDER_ENABLED=true
# YandexGPT (RF-resident): service-account API key + folder id.
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
# GigaChat: authorization key (base64 client_id:client_secret), scope, and the
# Russian Trusted Root CA path mounted into the gate container.
GIGACHAT_AUTH_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_CA_FILE=
# Foreign providers — honoured only when BLOCK_FOREIGN_LLM=false (non-RU):
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# Self-hosted OpenAI-compatible model inside the perimeter (vLLM/Ollama/TGI):
# set its endpoint here, e.g. http://vllm-host:8000/v1. Model→provider routing
# lives in config/gate/config.yaml (model_aliases).
LOCAL_LLM_BASE_URL=
LOCAL_LLM_API_KEY=
# Which model serves each duty (chat / light chat / embeddings) is assigned
# ONLY in the admin console after install: AI Settings → Providers → tag a
# model with the role. Applied to all services live — there are no model
# variables here by design.

# ── URLs / identity ───────────────────────────────────────────────────────────
# Public origins users reach the stack at (behind your TLS reverse-proxy).
# Used for deep links and SAML ACS; empty = localhost defaults (PoC).
PUBLIC_APP_URL=http://localhost:8080
ADMIN_APP_URL=http://localhost:8081
# First admin-console user, created on startup (idempotent — no-op if it exists).
BOOTSTRAP_ADMIN_EMAIL=admin@example.ru
# Seed password. PREFERRED: point BOOTSTRAP_ADMIN_PASSWORD_FILE at a mounted
# secret so the password never lands in env or the container log. If you set the
# password here inline instead, it lives in .env (keep .env out of shared logs).
# Leave BOTH empty for the legacy fallback: a one-time random password is printed
# ONCE to the admin-auth log (rotate it immediately — logs often ship to
# Loki/Elasticsearch/SIEM where it would persist).
# BOOTSTRAP_ADMIN_PASSWORD=
# BOOTSTRAP_ADMIN_PASSWORD_FILE=/run/secrets/bootstrap_admin_password

# ── Published ports ───────────────────────────────────────────────────────────
# APP_PORT=8080
# ADMIN_PORT=8081
# LANDING_PORT=8082

# ── Shared platform secrets ───────────────────────────────────────────────────
# Used by EVERY service — inter-service auth breaks if they diverge, so they are
# set once here, not per service. The compose defaults are shared dev values:
# fine for a PoC, MUST be rotated before production. Generate a fresh set with
#   ../scripts/rotate-secrets.sh
# and paste the block it prints (also written to secrets-summary.txt):
# INTERNAL_AUTH_SECRET=
# JWT_SECRET=
# ENCRYPTION_KEY=
# REDIS_PASSWORD=
# NEO4J_PASSWORD=
# CLICKHOUSE_PASSWORD=
